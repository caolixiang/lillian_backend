APP_ENV=local
PORT=8787
TASK_WORKER_CONCURRENCY=2
DB_POOL_MAX_CONNS=8
DB_POOL_MIN_CONNS=1

DATABASE_URL=postgres://admin:password@127.0.0.1:5432/lillian?sslmode=disable

ADMIN_TOKEN=replace-with-admin-token
LICENSE_KEY_PEPPER=replace-with-license-key-pepper
PROVIDER_CREDENTIAL_SECRET=replace-with-provider-secret

S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=lillian-canvas-images
S3_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key
S3_PUBLIC_BASE_URL=https://images.example.com
S3_FORCE_PATH_STYLE=true
