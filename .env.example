APP_ENV=local
PORT=8787
CORS_ORIGIN=http://127.0.0.1:5173
PUBLIC_API_BASE_URL=http://127.0.0.1:8787

POSTGRES_PORT=15432
DATABASE_URL=postgres://lillian:lillian@127.0.0.1:15432/lillian?sslmode=disable
AUTO_MIGRATE=true
MIGRATIONS_DIR=migrations

ADMIN_TOKEN=replace-with-admin-token
LICENSE_KEY_PEPPER=replace-with-license-key-pepper
PROVIDER_CREDENTIAL_SECRET=replace-with-provider-secret

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=lillian-images
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/lillian-images
S3_FORCE_PATH_STYLE=true
